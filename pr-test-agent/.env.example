# Zorunlu
OPENAI_API_KEY=sk-your-openai-api-key-here

# GitHub (public repo'lar için opsiyonel, private için zorunlu)
GITHUB_TOKEN=ghp_your-github-token-here

# Test edilen uygulamanın URL'si
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Playwright MCP server (npm run mcp:start ile başlatılır)
PLAYWRIGHT_MCP_HOST=localhost
PLAYWRIGHT_MCP_PORT=8931
PLAYWRIGHT_HEADLESS=true

# Test çıktı dizini (projenin içinde)
TEST_OUTPUT_DIR=tests/generated
REPORT_DIR=reports

# API server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Agent davranışı
OPENAI_MODEL=gpt-4o
MAX_AGENT_TURNS=20
AGENT_TIMEOUT=300
